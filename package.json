{
    "name": "shootix",
    "version": "1.0.4",
    "description": "Shootix - Studio Management System",
    "main": "electron/main.js",
    "scripts": {
        "frontend:dev": "npm --prefix frontend run dev",
        "backend:dev": "npm --prefix backend run dev",
        "dev": "concurrently \"npm run backend:dev\" \"wait-on http://127.0.0.1:5055 && npm run frontend:dev\" \"wait-on http://localhost:5173 && electron .\"",
        "build": "npm --prefix frontend run build && electron-builder"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "build": {
        "appId": "com.shootix.management",
        "productName": "Shootix",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "electron/**/*",
            "backend/**/*",
            "frontend/dist/**/*",
            "package.json"
        ],
        "win": {
            "icon": "frontend/src/assets/logo.png",
            "target": [
                "nsis"
            ]
        },
        "mac": {
            "icon": "frontend/src/assets/logo_mac.png",
            "category": "public.app-category.business",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "publish": {
            "provider": "github",
            "owner": "ElAmirr",
            "repo": "photo_invoice"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ElAmirr/photo_invoice.git"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "electron": "^34.3.0",
        "electron-builder": "^25.1.8",
        "wait-on": "^8.0.2"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "electron-updater": "^6.8.3",
        "express": "^5.2.1",
        "jimp": "^1.6.0",
        "multer": "^2.1.1",
        "mysql2": "^3.20.0",
        "uuid": "^13.0.0"
    }
}