{
    "name": "photo-studio-management",
    "version": "1.0.0",
    "description": "Photo Studio Management System",
    "main": "electron/main.js",
    "scripts": {
        "frontend:dev": "npm --prefix frontend run dev",
        "backend:dev": "npm --prefix backend run dev",
        "dev": "concurrently \"npm run backend:dev\" \"wait-on http://localhost:5001 && npm run frontend:dev\" \"wait-on http://localhost:5173 && electron .\"",
        "build": "npm --prefix frontend run build && electron-builder",
        "postinstall": "npm install --prefix frontend && npm install --prefix backend"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "build": {
        "appId": "com.photostudio.management",
        "productName": "Photo Studio Management",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "backend/**/*",
            "frontend/dist/**/*",
            "package.json"
        ],
        "mac": {
            "category": "public.app-category.business",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "publish": {
            "provider": "github",
            "owner": "ElAmirr",
            "repo": "photo_invoice"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ElAmirr/photo_invoice.git"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "electron": "^34.3.0",
        "electron-builder": "^25.1.8",
        "wait-on": "^8.0.2"
    },
    "dependencies": {
        "electron-updater": "^6.8.3"
    }
}